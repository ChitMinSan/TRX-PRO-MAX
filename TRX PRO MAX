<!DOCTYPE html>
<html lang="my">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>RISK TRX PRO - TRX Predictor</title>
<style>
  body {
    background-color: #0a0a0a;
    color: #00eaff;
    font-family: Arial, sans-serif;
    text-align: center;
  }
  .container, .trx {
    margin-top: 60px;
  }
  input {
    width: 220px;
    padding: 10px;
    border-radius: 10px;
    border: none;
    text-align: center;
    font-size: 18px;
    outline: none;
  }
  button {
    border: none;
    padding: 10px 20px;
    border-radius: 10px;
    font-size: 16px;
    font-weight: bold;
    margin: 5px;
  }
  .hidden { display: none; }
  .result {
    margin-top: 20px;
    font-size: 26px;
    font-weight: bold;
  }
  .num-btn {
    background-color: #1a1a1a;
    color: #fff;
    width: 60px;
    height: 60px;
    border-radius: 10px;
    font-size: 20px;
    margin: 5px;
  }
  .clear-btn {
    background-color: #ff4444;
    color: white;
    width: 130px;
    height: 50px;
    font-weight: bold;
    border-radius: 10px;
  }
  .predict-btn {
    background-color: #00ffc8;
    color: black;
    width: 180px;
    height: 50px;
    font-weight: bold;
    border-radius: 10px;
  }
  .winlose-btn {
    width: 100px;
    height: 45px;
    font-size: 18px;
    color: white;
    border-radius: 10px;
  }
  .win-btn {
    background-color: #00ff90;
  }
  .lose-btn {
    background-color: #ff4b4b;
  }
  .history {
    margin-top: 20px;
    font-size: 18px;
  }

  /* Telegram Button */
  .telegram-btn {
    display: inline-block;
    margin-top: 25px;
    background-color: #0088cc;
    color: white;
    padding: 12px 25px;
    border-radius: 10px;
    font-size: 18px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .telegram-btn:hover {
    background-color: #007ab8;
  }
</style>
</head>
<body>

<!-- 🔐 LOGIN PAGE -->
<div class="container" id="loginPage">
  <h2>🔐 RISK TRX PRO Login</h2>
  <input type="text" id="keyInput" placeholder="Enter KEY">
  <br><br>
  <button onclick="checkKey()">LOGIN</button>

  <!-- ✅ Telegram bot link before login -->
  <br><br>
  <a href="https://t.me/TRXPROMAX10_BOT" target="_blank" class="telegram-btn">
    🤖 Open @TRXPROMAX10_BOT
  </a>
</div>

<!-- 💎 MAIN TRX PREDICTOR PAGE -->
<div class="trx hidden" id="trxPage">
  <h2>💎 TRX Predictor</h2>
  <p>Enter 10 Digits (0-9)</p>
  <input type="text" id="digitsInput" maxlength="10" readonly placeholder="Tap numbers below">
  <br><br>
  <div id="numPad">
    <div>
      <button class="num-btn" onclick="addDigit(1)">1</button>
      <button class="num-btn" onclick="addDigit(2)">2</button>
      <button class="num-btn" onclick="addDigit(3)">3</button>
      <button class="num-btn" onclick="addDigit(4)">4</button>
      <button class="num-btn" onclick="addDigit(5)">5</button>
    </div>
    <div>
      <button class="num-btn" onclick="addDigit(6)">6</button>
      <button class="num-btn" onclick="addDigit(7)">7</button>
      <button class="num-btn" onclick="addDigit(8)">8</button>
      <button class="num-btn" onclick="addDigit(9)">9</button>
      <button class="num-btn" onclick="addDigit(0)">0</button>
    </div>
  </div>
  <br>
  <button class="clear-btn" onclick="clearDigits()">CLEAR</button>
  <br><br>
  <button class="predict-btn" onclick="predict()">PREDICT RESULT</button>
  <div class="result" id="result"></div>

  <!-- ✅ Win / Lose Section -->
  <div class="winlose hidden" id="winloseSection">
    <h3>📊 Record Result</h3>
    <button class="winlose-btn win-btn" onclick="recordResult('Win')">WIN</button>
    <button class="winlose-btn lose-btn" onclick="recordResult('Lose')">LOSE</button>
    <div class="history" id="history"></div>
  </div>

  <!-- ✅ Telegram bot link after result -->
  <a href="https://t.me/TRXPROMAX10_BOT/Subscriberpredict_Bot" 
     target="_blank" class="telegram-btn">
     🔗 Open TRX PRO MAX Bot
  </a>
</div>

<script>
let historyData = [];

// ✅ Login Check
function checkKey() {
  const key = document.getElementById("keyInput").value.trim();
  if (key === "RISK TRX PRO") {
    document.getElementById("loginPage").classList.add("hidden");
    document.getElementById("trxPage").classList.remove("hidden");
  } else {
    alert("❌ Invalid Key!");
  }
}

// ✅ Number Pad Logic
function addDigit(num) {
  const input = document.getElementById("digitsInput");
  if (input.value.length < 10) {
    input.value += num;
  }
}

// ✅ Clear Digits
function clearDigits() {
  document.getElementById("digitsInput").value = "";
  document.getElementById("result").innerText = "";
  document.getElementById("winloseSection").classList.add("hidden");
}

// ✅ Prediction Logic
function predict() {
  const input = document.getElementById("digitsInput").value.trim();
  if (input.length !== 10) {
    alert("Please enter exactly 10 digits!");
    return;
  }

  let sum = 0;
  for (let i = 0; i < input.length; i++) {
    sum += parseInt(input[i]);
  }

  // Reduce to single digit
  while (sum >= 10) {
    sum = sum.toString().split("").reduce((a, b) => a + parseInt(b), 0);
  }

  let resultText = "";
  if (sum <= 4) {
    resultText = "🔹 SMALL (" + sum + ")";
    document.getElementById("result").style.color = "#00ff90";
  } else {
    resultText = "🔸 BIG (" + sum + ")";
    document.getElementById("result").style.color = "#ff4b4b";
  }

  document.getElementById("result").innerText = resultText;
  document.getElementById("winloseSection").classList.remove("hidden");
}

// ✅ Record Win/Lose
function recordResult(status) {
  const result = document.getElementById("result").innerText;
  if (!result) return;

  const entry = `${result} ➤ ${status}`;
  historyData.unshift(entry);
  if (historyData.length > 10) historyData.pop();

  document.getElementById("history").innerHTML = historyData
    .map((e, i) => `<div>${i + 1}. ${e}</div>`)
    .join("");
}
</script>

</body>
</html>
